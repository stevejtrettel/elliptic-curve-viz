{
  "name": "elliptic-curve-viz",
  "version": "0.1.0",
  "private": true,
  "description": "Elliptic curves over finite fields, drawn on flat tori in S³ via the Hopf fibration",
  "type": "module",
  "scripts": {
    "dev": "node scripts/run-demo.mjs dev",
    "build": "node scripts/run-demo.mjs build",
    "preview": "node scripts/run-demo.mjs preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "points": "node --experimental-transform-types --disable-warning=ExperimentalWarning --import ./scripts/_register.mjs scripts/list-points.ts",
    "solve": "node --experimental-transform-types --disable-warning=ExperimentalWarning --import ./scripts/_register.mjs scripts/solve-tau.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint ."
  },
  "dependencies": {
    "three": "^0.185.0",
    "three-gpu-pathtracer": "^0.0.24"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/three": "^0.185.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^8.0.0",
    "vitest": "^4.0.0"
  }
}
